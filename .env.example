# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Ra7ti – Root environment variables                                   ║
# ║  Copy to .env and fill in values before running docker-compose        ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=ra7ti

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Domains (used by Traefik / Coolify labels) ───────────────────────────────
API_DOMAIN=api.yourdomain.com
APP_DOMAIN=app.yourdomain.com

# ── Coolify / Traefik ────────────────────────────────────────────────────────
# The external Docker network that Traefik listens on.
# In Coolify this is usually "coolify" – check your Coolify network settings.
TRAEFIK_NETWORK=coolify

# ── Container registry (for pre-built images, optional) ─────────────────────
REGISTRY=ghcr.io
IMAGE_NAMESPACE=your-github-username/ra7ti
IMAGE_TAG=latest

# ── Commission & Boost pricing ───────────────────────────────────────────────
DEFAULT_COMMISSION_RATE=5.0
BOOST_BASIC_PRICE=5
BOOST_STANDARD_PRICE=12
BOOST_PREMIUM_PRICE=25
