# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/ra7ti?schema=public"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Commission (platform defaults – overridable per company) ────────────────
DEFAULT_COMMISSION_RATE=5.0   # percent

# ─── Boost package prices (USD) ─────────────────────────────────────────────
BOOST_BASIC_PRICE=5
BOOST_STANDARD_PRICE=12
BOOST_PREMIUM_PRICE=25
